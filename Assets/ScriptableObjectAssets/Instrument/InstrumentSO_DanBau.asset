  m_Script: {fileID: 11500000, guid: bdeffcbf521f5c64595fa950da9cc2e4, type: 3}
  m_Name: InstrumentSO_DanBau
  m_EditorClassIdentifier: 
  instrumentName: "\u0110\xE0n b\u1EA7u"
  description: "\u0110\xE0n b\u1EA7u l\xE0 m\u1ED9t lo\u1EA1i nh\u1EA1c c\u1EE5 d\xE2n
    t\u1ED9c \u0111\u1ED9c \u0111\xE1o c\u1EE7a Vi\u1EC7t Nam, ch\u1EC9 c\xF3 m\u1ED9t
    d\xE2y nh\u01B0ng c\xF3 th\u1EC3 t\u1EA1o ra nhi\u1EC1u cao \u0111\u1ED9 kh\xE1c
    nhau nh\u1EDD k\u1EF9 thu\u1EADt \u0111i\u1EC1u khi\u1EC3n \xE2m thanh b\u1EB1ng
    tay g\u1EA3y v\xE0 c\u1EA7n \u0111i\u1EC1u ch\u1EC9nh. Th\xE2n \u0111\xE0n th\u01B0\u1EDDng
    l\xE0m b\u1EB1ng g\u1ED7, d\xE2y kim lo\u1EA1i, v\xE0 m\u1ED9t b\u1EA7u c\u1ED9ng
    h\u01B0\u1EDFng (th\u01B0\u1EDDng l\xE0m b\u1EB1ng qu\u1EA3 b\u1EA7u kh\xF4 ho\u1EB7c
    g\u1ED7). \xC2m thanh c\u1EE7a \u0111\xE0n b\u1EA7u m\u1EC1m m\u1EA1i, s\xE2u
    l\u1EAFng, r\u1EA5t bi\u1EC3u c\u1EA3m, th\u01B0\u1EDDng \u0111\u01B0\u1EE3c
    d\xF9ng \u0111\u1EC3 \u0111\u1ED9c t\u1EA5u, h\xF2a t\u1EA5u ho\u1EB7c \u0111\u1EC7m
    cho h\xE1t. \u0110\xE0n b\u1EA7u l\xE0 bi\u1EC3u t\u01B0\u1EE3ng tinh t\u1EBF
    c\u1EE7a \xE2m nh\u1EA1c truy\u1EC1n th\u1ED1ng Vi\u1EC7t Nam."
  videoClip: {fileID: 32900000, guid: 5c01b108821da4347949690a5803adf0, type: 3}
  videoClipTitle: "TR\u1ED0NG C\u01A0M | \u0110\xE0n B\u1EA7u Huy\u1EC1n Ly"
